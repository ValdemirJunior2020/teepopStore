# server/.env.example

PORT=8080
CLIENT_URL=http://localhost:5173

PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Firebase Admin - choose ONE method.
# Method 1: base64 service account JSON, best for Render.
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Method 2: raw service account JSON, okay locally if escaped correctly.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Method 3: separate fields.
FIREBASE_PROJECT_ID=agents-name
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
ORDER_ALERT_EMAIL=infojr.83@gmail.com
